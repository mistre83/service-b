{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:base"],
  "packageRules": [
    {
      "matchManagers": ["composer"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "composer dependencies",
      "schedule": ["on monday"]
    }
  ],
  "major": {
    "enabled": false
  }
}
